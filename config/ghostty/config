shell-integration = fish
font-family = Hack Nerd Font
term = xterm-256color
desktop-notifications = true
unfocused-split-opacity = 0.55
background-opacity = 0.9
background-blur = 15
quick-terminal-autohide = false
quick-terminal-size = 100%,100%
quick-terminal-keyboard-interactivity = exclusive

# Catppuccin Mocha (also drives herdr's "terminal" theme)
theme = catppuccin-mocha
font-size = 12
window-padding-x = 12
window-padding-y = 12
macos-titlebar-style = hidden
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor
mouse-hide-while-typing = true
scrollback-limit = 50000
macos-option-as-alt = true
fullscreen = true
macos-non-native-fullscreen = true

# Keybindings
keybind = opt+left=text:\x1bb
keybind = opt+right=text:\x1bf
keybind = cmd+left=text:\x01
keybind = cmd+right=text:\x05
keybind = opt+backspace=text:\x1b\x7f
keybind = cmd+backspace=text:\x15
keybind = cmd+enter=toggle_fullscreen
keybind = cmd+t=text:\x1cc
keybind = cmd+d=text:\x1bd
keybind = cmd+shift+d=text:\x1bD
keybind = cmd+w=text:\x1bw
keybind = ctrl+tab=text:\x1cn
keybind = ctrl+shift+tab=text:\x1cp
keybind = cmd+comma=text:\x1b,
keybind = shift+enter=text:\n
keybind = ctrl+super+space=text:\x1b[32;13~
keybind = super+i=text:\x1b[105;13~
keybind = super+n=text:\x1b[110;13~
keybind = cmd+c=text:\x1b[99;13~
keybind = shift+enter=text:\x1b\r
